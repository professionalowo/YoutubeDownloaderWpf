<Window x:Class="YoutubeDownloader.Wpf.View.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Youtube Downloader" Height="600" Width="900">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e0e0e0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HamburgerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e0e0e0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="50"/>
        </Grid.ColumnDefinitions>

        <!-- Column 0: Hamburger Button -->
        <Button Grid.Column="0"
                Content="☰" 
                Click="ToggleNavButton_Click" 
                Width="40" 
                Height="40" 
                Margin="5" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Center"
                Style="{StaticResource HamburgerButtonStyle}"/>

        <!-- Column 1: Main Content -->
        <Frame Grid.Column="1" x:Name="MainFrame" NavigationUIVisibility="Hidden" />

        <!-- Flyout Navigation Panel -->
        <Border x:Name="NavPanel" 
                Grid.Column="0" Grid.ColumnSpan="3"
                Background="#f0f0f0" 
                BorderBrush="#dcdcdc" 
                BorderThickness="0,0,1,0" 
                Width="200" 
                Visibility="Collapsed" 
                HorizontalAlignment="Left"
                Panel.ZIndex="1">
            <Grid>
                <Button Content="☰" 
                        Click="ToggleNavButton_Click" 
                        Width="40" 
                        Height="40" 
                        Margin="5" 
                        VerticalAlignment="Top" 
                        HorizontalAlignment="Left"
                        Style="{StaticResource HamburgerButtonStyle}"/>
                
                <ListBox SelectionChanged="NavListBox_SelectionChanged" Background="Transparent" BorderThickness="0" Margin="0,50,0,0">
                    <ListBoxItem Style="{StaticResource NavButtonStyle}">Download</ListBoxItem>
                    <ListBoxItem Style="{StaticResource NavButtonStyle}">Settings</ListBoxItem>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>

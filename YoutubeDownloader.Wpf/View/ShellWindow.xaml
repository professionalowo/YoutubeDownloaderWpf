<Window x:Class="YoutubeDownloader.Wpf.View.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Youtube Downloader" Height="600" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#f0f0f0" BorderBrush="#dcdcdc" BorderThickness="0,0,1,0">
            <StackPanel>
                <Button Content="Download" Click="NavigateToDownload_Click" Margin="10" Padding="10,5"/>
                <Button Content="Settings" Click="NavigateToSettings_Click" Margin="10,0,10,10" Padding="10,5"/>
            </StackPanel>
        </Border>

        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" />
    </Grid>
</Window>


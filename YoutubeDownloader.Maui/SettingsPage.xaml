<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="YoutubeDownloader.Maui.SettingsPage"
             Title="Settings">
    <Grid Padding="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Text="Download Path:" VerticalOptions="Center" />
        <Entry Grid.Row="0" Grid.Column="1" x:Name="DownloadPathEntry" VerticalOptions="Center" Margin="5" />

        <Button Grid.Row="1" Grid.Column="1" Text="Save" Clicked="SaveButton_Clicked" HorizontalOptions="End" Margin="5" />
    </Grid>
</ContentPage>
